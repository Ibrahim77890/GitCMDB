{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ComplianceSchema",
  "description": "Captures configuration assessment compliance logs and attestation traces.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "policy_id": {
      "type": "string",
      "pattern": "^COMP-[0-9]{4}$"
    },
    "scope": {
      "type": "string",
      "enum": ["global", "host", "network", "service"]
    },
    "status": {
      "type": "string",
      "enum": ["compliant", "non-compliant", "exempt"]
    },
    "last_assessed": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "auditor": {
      "type": "string"
    }
  },
  "required": ["policy_id", "scope", "status", "last_assessed"]
}