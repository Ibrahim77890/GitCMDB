{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Service",
  "type": "object",
  "properties": {
    "service_name": { "type": "string" },
    "environment": { "type": "string" },
    "tier": { "type": "string", "enum": ["frontend", "backend", "database", "cache"] },
    "owner": { "type": "string" },
    "port": { "type": "integer" }
  },
  "required": ["service_name", "environment", "tier"]
}
