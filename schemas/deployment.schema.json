{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DeploymentSchema",
  "description": "Structural schema tracking cluster deployment metrics and software rollout changes.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "deployment_id": {
      "type": "string",
      "pattern": "^dep-[0-9a-f]{8}$"
    },
    "service_name": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "deployed_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "result": {
      "type": "string",
      "enum": ["success", "failed", "rolled_back"]
    }
  },
  "required": ["deployment_id", "service_name", "version", "deployed_at", "result"]
}